# Demonstration
def demonstration(task, shots, examples=few_shot_examples):
    # Unpack positive and negative examples from the provided examples list
    positive_list, negative_list = examples
    # How many examples to take from each class (positive/negative)
    number_of_each = shots // 2

    demonstration_prompt_sentiment_only = "Παρακάτω ακολουθούν παραδείγματα κριτικών ταινιών με το αντίστοιχο συναίσθημα:\n"
    demonstration_prompt_sentiment_then_explanation = "Παρακάτω ακολουθούν παραδείγματα κριτικών ταινιών με το αντίστοιχο συναίσθημα και εξήγηση:\n"
    demonstration_prompt_explanation_then_sentiment = "Παρακάτω ακολουθούν παραδείγματα κριτικών ταινιών με την αντίστοιχη εξήγηση και συναίσθημα:\n"
    if task == f"{shots}_shot_sentiment_only":
      for i in range(number_of_each):
        for k in (positive_list, negative_list):
          review, label, explanation = k[i]
          demonstration_prompt_sentiment_only += f"Κριτική: «{review}»\n"
          demonstration_prompt_sentiment_only += f"Συναίσθημα: {label}\n"
      return demonstration_prompt_sentiment_only
    elif task == f"{shots}_shot_sentiment_then_explanation":
      for i in range(number_of_each):
        for k in (positive_list, negative_list):
          review, label, explanation = k[i]
          demonstration_prompt_sentiment_then_explanation += f"Κριτική: «{review}»\n"
          demonstration_prompt_sentiment_then_explanation += f"Συναίσθημα: {label}\n"
          demonstration_prompt_sentiment_then_explanation += f"Εξήγηση: {explanation}\n"
      return demonstration_prompt_sentiment_then_explanation
    elif task == f"{shots}_shot_explanation_then_sentiment":
      for i in range(number_of_each):
        for k in (positive_list, negative_list):
          review, label, explanation = k[i]
          demonstration_prompt_explanation_then_sentiment += f"Κριτική: «{review}»\n"
          demonstration_prompt_explanation_then_sentiment += f"Εξήγηση: {explanation}\n"
          demonstration_prompt_explanation_then_sentiment += f"Συναίσθημα: {label}\n"
      return demonstration_prompt_explanation_then_sentiment
    else:
      raise ValueError(f"Unknown task: {task}")

# Prompt template
def prompt_template(review_text, task, shots):
    base_instruction = (
        "Είσαι ένας ειδικός αναλυτής συναισθημάτων για κριτικές ταινιών.\n"
        "Ανάλυσε προσεκτικά την παρακάτω κριτική ταινίας και καθόρισε ξεκάθαρα αν εκφράζει θετικό ή αρνητικό συναίσθημα.\n"
        f"Κριτική: «{review_text}»\n"
    )
    if shots != 0:
      base_instruction = demonstration(task, shots) + base_instruction

    if task == f"{shots}_shot_sentiment_only":
        # Define a prompt template that instructs the model to identify sentiment
        return base_instruction + (
            "Απάντησε μόνο με μία από τις δύο λέξεις (θετικό ή αρνητικό) με την ακόλουθη μορφή:\n"
            "Συναίσθημα: [θετικό ή αρνητικό]\n"
            "Μην προσθέσεις καμία άλλη λέξη ή εξήγηση.\n"
            "Απάντηση:\n"
        )
    elif task == f"{shots}_shot_sentiment_then_explanation":
        # Define a prompt template that instructs the model to identify sentiment and explain it
        return base_instruction + (
            "Απάντησε υποχρεωτικά και στα δύο ζητούμενα με την ακόλουθη μορφή:\n"
            "Συναίσθημα: [θετικό ή αρνητικό]\n"
            "Εξήγηση: [σύντομη εξήγηση 1-2 προτάσεων]\n"
            "Είναι απαραίτητο να παρέχεις και τα δύο (Συναίσθημα και Εξήγηση).\n"
            "Απάντηση:\n"
        )
    elif task == f"{shots}_shot_explanation_then_sentiment":
        # Define a prompt template that instructs the model to explain sentiment and identify it
        return base_instruction + (
            "Απάντησε υποχρεωτικά και στα δύο ζητούμενα με την ακόλουθη μορφή:\n"
            "Εξήγηση: [σύντομη εξήγηση 1-2 προτάσεων]\n"
            "Συναίσθημα: [θετικό ή αρνητικό]\n"
            "Είναι απαραίτητο να παρέχεις και τα δύο (Εξήγηση και Συναίσθημα).\n"
            "Απάντηση:\n"
        )
    else:
      raise ValueError(f"Unknown task: {task}")

# Checkpointing
def checkpoint(checkpoint_path):
  # Load previous results from checkpoint, if it exists
  if os.path.exists(checkpoint_path):
    results_df = pd.read_csv(checkpoint_path)
    processed_reviews = set(results_df["greek_review"])
    print(f"Resuming from checkpoint. Already processed: {len(processed_reviews)} reviews.")
  else:
    results_df = pd.DataFrame(columns=["greek_review", "model_output"])
    processed_reviews = set()
  return results_df, processed_reviews

# Prediction
def predict(test_df, llm, prompt_template, checkpoint_path, final_output_path, processed_reviews, results_df, task, shots):
  new_rows = []

  # Iterate through the test dataset with progress bar
  for i, row in tqdm(test_df.iterrows(), total=len(test_df)):
    review = row["translation"]

    # Skip, if this review has already been processed in a previous run (checkpointing)
    if review in processed_reviews:
      continue

    prompt = prompt_template(review, task, shots)

    try:
      # Run the Llama-Krikri model with the generated prompt
      output = llm(
        prompt,
        max_tokens=200,
        temperature=0.1,
        top_p=0.9,
        seed=42
      )

      # Extract the model's answer text from the output structure
      answer = output["choices"][0]["text"].strip()

    # If an error occurs during generation, store the error message instead
    except Exception as e:
        answer = f"Error: {e}"

    # Store the review and model's response in dictionary format
    new_rows.append({
        "greek_review": review,
        "model_output": answer
    })

    # Save a checkpoint every 10 samples to prevent data loss
    if i % 10 == 0:
      pd.concat([results_df, pd.DataFrame(new_rows)], ignore_index=True).to_csv(checkpoint_path, index=False)

  # Final save after the loop ends
  results_df = pd.concat([results_df, pd.DataFrame(new_rows)], ignore_index=True)
  results_df.to_csv(checkpoint_path, index=False)
  results_df.to_csv(final_output_path, index=False)

